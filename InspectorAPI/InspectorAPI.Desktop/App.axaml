<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InspectorAPI.Desktop.App"
             RequestedThemeVariant="Default">

  <Application.Styles>
    <FluentTheme />
  </Application.Styles>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>

        <ResourceDictionary x:Key="Dark">
          <!-- Backgrounds -->
          <SolidColorBrush x:Key="AppBg"        Color="#1A1A1A" />
          <SolidColorBrush x:Key="SidebarBg"    Color="#1E1E1E" />
          <SolidColorBrush x:Key="HeaderBg"     Color="#161616" />
          <SolidColorBrush x:Key="TabbarBg"     Color="#252525" />
          <SolidColorBrush x:Key="InputBg"      Color="#2A2A2A" />
          <SolidColorBrush x:Key="SelectionBg"  Color="#2D2D2D" />
          <SolidColorBrush x:Key="HoverBg"      Color="#2A2A2A" />
          <SolidColorBrush x:Key="DialogBg"     Color="#252525" />
          <!-- Borders -->
          <SolidColorBrush x:Key="BorderColor"       Color="#3A3A3A" />
          <SolidColorBrush x:Key="ButtonBorderColor" Color="#4A4A4A" />
          <SolidColorBrush x:Key="DialogBorderColor" Color="#5A5A5A" />
          <!-- Buttons -->
          <SolidColorBrush x:Key="BtnSecondaryBg" Color="#333333" />
          <SolidColorBrush x:Key="DisabledBg"     Color="#444444" />
          <!-- Text -->
          <SolidColorBrush x:Key="TextPrimary"    Color="#DDDDDD" />
          <SolidColorBrush x:Key="TextSecondary"  Color="#CCCCCC" />
          <SolidColorBrush x:Key="TextMuted"      Color="#AAAAAA" />
          <SolidColorBrush x:Key="TextFaint"      Color="#888888" />
          <SolidColorBrush x:Key="TextVeryFaint"  Color="#666666" />
          <SolidColorBrush x:Key="TextLabel"      Color="#777777" />
          <SolidColorBrush x:Key="TextHeaderKey"  Color="#909090" />
          <!-- Misc -->
          <SolidColorBrush x:Key="TextSelectionBrush" Color="#4A4A4A" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Light">
          <!-- Backgrounds -->
          <SolidColorBrush x:Key="AppBg"        Color="#F5F5F5" />
          <SolidColorBrush x:Key="SidebarBg"    Color="#EEEEEE" />
          <SolidColorBrush x:Key="HeaderBg"     Color="#E4E4E4" />
          <SolidColorBrush x:Key="TabbarBg"     Color="#E8E8E8" />
          <SolidColorBrush x:Key="InputBg"      Color="#FFFFFF" />
          <SolidColorBrush x:Key="SelectionBg"  Color="#E0E0E0" />
          <SolidColorBrush x:Key="HoverBg"      Color="#E8E8E8" />
          <SolidColorBrush x:Key="DialogBg"     Color="#F0F0F0" />
          <!-- Borders -->
          <SolidColorBrush x:Key="BorderColor"       Color="#CACACA" />
          <SolidColorBrush x:Key="ButtonBorderColor" Color="#AAAAAA" />
          <SolidColorBrush x:Key="DialogBorderColor" Color="#999999" />
          <!-- Buttons -->
          <SolidColorBrush x:Key="BtnSecondaryBg" Color="#DCDCDC" />
          <SolidColorBrush x:Key="DisabledBg"     Color="#BBBBBB" />
          <!-- Text -->
          <SolidColorBrush x:Key="TextPrimary"    Color="#1A1A1A" />
          <SolidColorBrush x:Key="TextSecondary"  Color="#2A2A2A" />
          <SolidColorBrush x:Key="TextMuted"      Color="#444444" />
          <SolidColorBrush x:Key="TextFaint"      Color="#666666" />
          <SolidColorBrush x:Key="TextVeryFaint"  Color="#888888" />
          <SolidColorBrush x:Key="TextLabel"      Color="#555555" />
          <SolidColorBrush x:Key="TextHeaderKey"  Color="#404040" />
          <!-- Misc -->
          <SolidColorBrush x:Key="TextSelectionBrush" Color="#B8B8B8" />
        </ResourceDictionary>

      </ResourceDictionary.ThemeDictionaries>

      <!-- Method badge colors — theme-independent -->
      <SolidColorBrush x:Key="GetMethodBrush"     Color="#61AFFE" />
      <SolidColorBrush x:Key="PostMethodBrush"    Color="#49CC90" />
      <SolidColorBrush x:Key="PutMethodBrush"     Color="#FCA130" />
      <SolidColorBrush x:Key="DeleteMethodBrush"  Color="#F93E3E" />
      <SolidColorBrush x:Key="PatchMethodBrush"   Color="#50E3C2" />
      <SolidColorBrush x:Key="HeadMethodBrush"    Color="#9012FE" />
      <SolidColorBrush x:Key="OptionsMethodBrush" Color="#0D5AA7" />

    </ResourceDictionary>
  </Application.Resources>

</Application>
