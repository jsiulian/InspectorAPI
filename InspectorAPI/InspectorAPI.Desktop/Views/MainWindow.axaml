<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:InspectorAPI.Core.ViewModels"
        xmlns:conv="using:InspectorAPI.Desktop.Converters"
        x:Class="InspectorAPI.Desktop.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="InspectorAPI"
        Icon="avares://InspectorAPI/Assets/icon.ico"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        Background="{DynamicResource AppBg}">

  <Window.Styles>

    <!-- Sidebar button -->
    <Style Selector="Button.sidebar-btn">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="6,3" />
      <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
    </Style>
    <Style Selector="Button.sidebar-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SelectionBg}" />
    </Style>

    <!-- Tab button -->
    <Style Selector="Button.tab-btn">
      <Setter Property="Background" Value="{DynamicResource TabbarBg}" />
      <Setter Property="BorderThickness" Value="0,0,1,0" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Button.tab-btn.active">
      <Setter Property="Background" Value="{DynamicResource AppBg}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
    </Style>
    <Style Selector="Button.tab-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource HoverBg}" />
    </Style>
    <!-- Active tab: suppress hover so it stays visually "connected" to content -->
    <Style Selector="Button.tab-btn.active:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppBg}" />
    </Style>
    <!-- Active tab: underline the title text -->
    <Style Selector="Button.tab-btn.active TextBlock.tab-title">
      <Setter Property="TextDecorations" Value="Underline" />
    </Style>

    <!-- Close tab button -->
    <Style Selector="Button.close-btn">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="2,0" />
      <Setter Property="Foreground" Value="{DynamicResource TextFaint}" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Width" Value="20" />
      <Setter Property="Height" Value="20" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.close-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#CC3333" />
    </Style>

    <!-- Send button -->
    <Style Selector="Button.send-btn">
      <Setter Property="Background" Value="#7C6AF7" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="16,8" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="Button.send-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#9080FF" />
    </Style>
    <Style Selector="Button.send-btn:disabled /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource DisabledBg}" />
    </Style>

    <!-- New tab button -->
    <Style Selector="Button.new-tab-btn">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
      <Setter Property="FontSize" Value="18" />
    </Style>

    <!-- Add row button -->
    <Style Selector="Button.add-row-btn">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Margin" Value="8,4" />
    </Style>

    <!-- Remove row button -->
    <Style Selector="Button.remove-row-btn">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="4,2" />
      <Setter Property="Foreground" Value="{DynamicResource TextVeryFaint}" />
      <Setter Property="FontSize" Value="16" />
    </Style>
    <Style Selector="Button.remove-row-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#AA2222" />
      <Setter Property="TextElement.Foreground" Value="White" />
    </Style>

    <!-- TextBox base -->
    <Style Selector="TextBox">
      <Setter Property="Background" Value="{DynamicResource InputBg}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
      <Setter Property="CaretBrush" Value="#7C6AF7" />
      <Setter Property="SelectionBrush" Value="{DynamicResource TextSelectionBrush}" />
      <Setter Property="VerticalContentAlignment" Value="Center"></Setter>
    </Style>

    <Style Selector="TextBox[AcceptsReturn=True]">
      <Setter Property="VerticalContentAlignment" Value="Top"></Setter>
    </Style>
    
    <!-- ComboBox base -->
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="{DynamicResource InputBg}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
    </Style>

    <!-- TabItem -->
    <Style Selector="TabItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="TabItem:selected">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <!-- Tree item -->
    <Style Selector="TreeViewItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="2" />
    </Style>

    <!-- Method badge colors via classes -->
    <Style Selector="TextBlock.method-GET">
      <Setter Property="Foreground" Value="#61AFFE" />
    </Style>
    <Style Selector="TextBlock.method-POST">
      <Setter Property="Foreground" Value="#49CC90" />
    </Style>
    <Style Selector="TextBlock.method-PUT">
      <Setter Property="Foreground" Value="#FCA130" />
    </Style>
    <Style Selector="TextBlock.method-DELETE">
      <Setter Property="Foreground" Value="#F93E3E" />
    </Style>
    <Style Selector="TextBlock.method-PATCH">
      <Setter Property="Foreground" Value="#50E3C2" />
    </Style>
    <Style Selector="TextBlock.method-HEAD">
      <Setter Property="Foreground" Value="#9012FE" />
    </Style>
    <Style Selector="TextBlock.method-OPTIONS">
      <Setter Property="Foreground" Value="#0D5AA7" />
    </Style>

  </Window.Styles>

  <Grid ColumnDefinitions="280,4,*">

    <!-- ===== COLLECTIONS SIDEBAR ===== -->
    <DockPanel Grid.Column="0" Background="{DynamicResource SidebarBg}">

      <!-- Sidebar header -->
      <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBg}"
              BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderColor}"
              Padding="12,8">
        <Grid ColumnDefinitions="*,Auto,Auto">
          <TextBlock Grid.Column="0"
                     Text="COLLECTIONS"
                     FontSize="10" FontWeight="Bold"
                     Foreground="{DynamicResource TextLabel}"
                     VerticalAlignment="Center"
                     LetterSpacing="1" />
          <Button Grid.Column="1"
                  Classes="sidebar-btn"
                  Click="OnImportClick"
                  ToolTip.Tip="Import Collection (Native JSON or Postman)"
                  FontSize="14" Padding="4,0">⬇</Button>
          <Button Grid.Column="2"
                  Classes="sidebar-btn"
                  Command="{Binding NewCollectionCommand}"
                  ToolTip.Tip="New Collection"
                  FontSize="18" Padding="4,0">+</Button>
        </Grid>
      </Border>

      <!-- Collections tree -->
      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <TreeView ItemsSource="{Binding CollectionTree}"
                  Background="Transparent"
                  KeyDown="OnCollectionTreeKeyDown">
          <TreeView.ItemTemplate>
            <TreeDataTemplate x:DataType="vm:CollectionTreeNodeViewModel"
                              ItemsSource="{Binding Children}">
              <!-- Transparent background needed so the full row width is hittable for the ContextMenu -->
              <Border Background="Transparent" HorizontalAlignment="Stretch"
                      DoubleTapped="OnTreeNodeDoubleTapped">

                <Border.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Open in Tab"
                              Command="{Binding OpenCommand}"
                              IsVisible="{Binding IsRequest}" />
                    <MenuItem Header="New Folder"
                              Command="{Binding NewFolderCommand}"
                              IsVisible="{Binding IsCollectionOrFolder}" />
                    <MenuItem Header="New Request"
                              Command="{Binding NewRequestCommand}"
                              IsVisible="{Binding IsCollectionOrFolder}" />
                    <MenuItem Header="Rename"
                              Command="{Binding RenameCommand}" />
                    <Separator IsVisible="{Binding IsCollection}" />
                    <MenuItem Header="Export (Native JSON)"
                              Command="{Binding ExportNativeCommand}"
                              IsVisible="{Binding IsCollection}" />
                    <MenuItem Header="Export (Postman v2.1)"
                              Command="{Binding ExportPostmanCommand}"
                              IsVisible="{Binding IsCollection}" />
                    <Separator />
                    <MenuItem Header="Delete"
                              Command="{Binding DeleteCommand}"
                              Foreground="#F93E3E" />
                  </ContextMenu>
                </Border.ContextMenu>

                <Grid ColumnDefinitions="Auto,*" Margin="0,1">

                  <!-- Icon / method badge -->
                  <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                    <TextBlock Text="{Binding Icon}"
                               FontSize="11"
                               Foreground="{DynamicResource TextLabel}"
                               IsVisible="{Binding IsNotRequest}" />
                    <TextBlock Text="{Binding MethodBadge}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{Binding MethodBadge, Converter={x:Static conv:MethodBrushConverter.Instance}}"
                               IsVisible="{Binding IsRequest}"
                               VerticalAlignment="Center" />
                  </StackPanel>

                  <!-- Node name -->
                  <TextBlock Grid.Column="1"
                             Text="{Binding Name}"
                             VerticalAlignment="Center"
                             Margin="4,0"
                             TextTrimming="CharacterEllipsis" />

                </Grid>
              </Border>
            </TreeDataTemplate>
          </TreeView.ItemTemplate>
        </TreeView>
      </ScrollViewer>
    </DockPanel>

    <!-- Vertical splitter -->
    <GridSplitter Grid.Column="1"
                  Background="{DynamicResource BorderColor}"
                  ResizeDirection="Columns" />

    <!-- ===== MAIN CONTENT ===== -->
    <Grid Grid.Column="2" RowDefinitions="Auto,*" Background="{DynamicResource AppBg}">

      <!-- Tab bar row -->
      <DockPanel Grid.Row="0" Background="{DynamicResource TabbarBg}"
                 LastChildFill="True">

        <!-- New tab button -->
        <Button DockPanel.Dock="Right"
                Classes="new-tab-btn"
                Command="{Binding AddNewTabCommand}"
                ToolTip.Tip="New Request"
                VerticalAlignment="Center">+</Button>

        <!-- Tab strip -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding Tabs}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:RequestTabViewModel">
                <Border BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderColor}">
                  <Button Classes="tab-btn"
                          Classes.active="{Binding IsSelected}"
                          Command="{Binding ActivateCommand}">
                    <ToolTip.Tip>
                      <StackPanel Spacing="2">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Url}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFaint}"
                                   IsVisible="{Binding Url, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                      </StackPanel>
                    </ToolTip.Tip>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding SelectedMethod}"
                                 FontSize="10" FontWeight="Bold"
                                 VerticalAlignment="Center"
                                 Foreground="{Binding SelectedMethod, Converter={x:Static conv:MethodBrushConverter.Instance}}" />
                      <TextBlock Text="{Binding TabTitle}"
                                 Classes="tab-title"
                                 MaxWidth="140"
                                 TextTrimming="CharacterEllipsis"
                                 VerticalAlignment="Center" />
                      <Button Classes="close-btn"
                              Command="{Binding CloseCommand}"
                              VerticalAlignment="Center">×</Button>
                    </StackPanel>
                  </Button>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </DockPanel>

      <!-- Tab content area -->
      <ContentControl Grid.Row="1" Content="{Binding SelectedTab}">
        <ContentControl.DataTemplates>
          <DataTemplate x:DataType="vm:RequestTabViewModel">

            <Grid RowDefinitions="Auto,*,5,300">

              <!-- ===== REQUEST BAR ===== -->
              <Border Grid.Row="0" Padding="10,8"
                      Background="{DynamicResource SidebarBg}"
                      BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderColor}">
                <Grid ColumnDefinitions="150,*,Auto,Auto,Auto">

                  <!-- Method selector -->
                  <ComboBox Grid.Column="0"
                            ItemsSource="{x:Static vm:RequestTabViewModel.HttpMethods}"
                            SelectedItem="{Binding SelectedMethod}"
                            Padding="8,6"
                            FontWeight="Bold"
                            FontSize="13" />

                  <!-- URL input -->
                  <TextBox Grid.Column="1"
                           Text="{Binding Url}"
                           Watermark="https://api.example.com/endpoint"
                           Margin="6,0"
                           FontFamily="Consolas,Courier New,monospace"
                           FontSize="13"
                           Padding="10,6" />

                  <!-- Send button -->
                  <Button Grid.Column="2"
                          Classes="send-btn"
                          Command="{Binding SendRequestCommand}"
                          IsVisible="{Binding !IsSending}">Send</Button>

                  <!-- Cancel button -->
                  <Button Grid.Column="2"
                          Background="#AA3333"
                          Foreground="White"
                          BorderThickness="0"
                          Padding="12,8"
                          CornerRadius="4"
                          Command="{Binding CancelRequestCommand}"
                          IsVisible="{Binding IsSending}">Cancel</Button>

                  <!-- Save button -->
                  <Button Grid.Column="3"
                          Background="{DynamicResource SelectionBg}"
                          Foreground="{DynamicResource TextSecondary}"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource ButtonBorderColor}"
                          Padding="12,8"
                          CornerRadius="4"
                          Margin="6,0,0,0"
                          Command="{Binding OpenSaveDialogCommand}">Save</Button>

                </Grid>
              </Border>

              <!-- ===== REQUEST CONFIGURATION TABS ===== -->
              <TabControl Grid.Row="1" Background="{DynamicResource AppBg}">

                <!-- Headers tab -->
                <TabItem Header="Headers">
                  <Grid RowDefinitions="*,Auto" Background="{DynamicResource AppBg}">
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                      <ItemsControl ItemsSource="{Binding Headers}" Margin="8,4">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:HeaderItemViewModel">
                            <Grid ColumnDefinitions="Auto,*,*,Auto" Margin="0,2">
                              <CheckBox Grid.Column="0"
                                        IsChecked="{Binding IsEnabled}"
                                        VerticalAlignment="Center"
                                        Margin="0,0,6,0" />
                              <AutoCompleteBox Grid.Column="1"
                                              Text="{Binding Key}"
                                              ItemsSource="{x:Static vm:RequestTabViewModel.CommonHeaders}"
                                              MinimumPrefixLength="1"
                                              FilterMode="StartsWith"
                                              Watermark="Header name"
                                              FontFamily="Consolas,monospace"
                                              FontSize="12"
                                              Padding="6,4"
                                              Margin="0,0,4,0" />
                              <TextBox Grid.Column="2"
                                       Text="{Binding Value}"
                                       Watermark="Value"
                                       FontFamily="Consolas,monospace"
                                       FontSize="12"
                                       Padding="6,4" />
                              <Button Grid.Column="3"
                                      Classes="remove-row-btn"
                                      Command="{Binding RemoveCommand}"
                                      Margin="4,0,0,0">×</Button>
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                    <Button Grid.Row="1"
                            Classes="add-row-btn"
                            Command="{Binding AddHeaderCommand}">+ Add Header</Button>
                  </Grid>
                </TabItem>

                <!-- Query Params tab -->
                <TabItem Header="Query Params">
                  <Grid RowDefinitions="*,Auto" Background="{DynamicResource AppBg}">
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                      <ItemsControl ItemsSource="{Binding QueryParams}" Margin="8,4">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:HeaderItemViewModel">
                            <Grid ColumnDefinitions="Auto,*,*,Auto" Margin="0,2">
                              <CheckBox Grid.Column="0"
                                        IsChecked="{Binding IsEnabled}"
                                        VerticalAlignment="Center"
                                        Margin="0,0,6,0" />
                              <TextBox Grid.Column="1"
                                       Text="{Binding Key}"
                                       Watermark="Parameter name"
                                       FontFamily="Consolas,monospace"
                                       FontSize="12"
                                       Padding="6,4"
                                       Margin="0,0,4,0" />
                              <TextBox Grid.Column="2"
                                       Text="{Binding Value}"
                                       Watermark="Value"
                                       FontFamily="Consolas,monospace"
                                       FontSize="12"
                                       Padding="6,4" />
                              <Button Grid.Column="3"
                                      Classes="remove-row-btn"
                                      Command="{Binding RemoveCommand}"
                                      Margin="4,0,0,0">×</Button>
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                    <Button Grid.Row="1"
                            Classes="add-row-btn"
                            Command="{Binding AddQueryParamCommand}">+ Add Parameter</Button>
                  </Grid>
                </TabItem>

                <!-- Body tab -->
                <TabItem Header="Body">
                  <Grid RowDefinitions="Auto,*" Background="{DynamicResource AppBg}">
                    <Border Grid.Row="0"
                            Padding="8,6"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource BorderColor}">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Content-Type:"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{x:Static vm:RequestTabViewModel.ContentTypes}"
                                  SelectedItem="{Binding SelectedBodyContentType}"
                                  FontSize="12"
                                  Padding="8,4" />
                      </StackPanel>
                    </Border>
                    <TextBox Grid.Row="1"
                             Text="{Binding BodyContent}"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas,Courier New,monospace"
                             FontSize="13"
                             Padding="12"
                             Background="{DynamicResource AppBg}"
                             BorderThickness="0"
                             Watermark="Request body (JSON, XML, text…)" />
                  </Grid>
                </TabItem>

                <!-- Auth tab (placeholder) -->
                <TabItem Header="Auth">
                  <Border Background="{DynamicResource AppBg}" Padding="16">
                    <StackPanel Spacing="12">
                      <TextBlock Text="Authentication" FontSize="14" Foreground="{DynamicResource TextPrimary}" />
                      <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextFaint}">
                        Add Authorization headers manually in the Headers tab.
                        Common patterns:&#10;
                        • Bearer token: Authorization: Bearer &lt;token&gt;&#10;
                        • Basic auth: Authorization: Basic &lt;base64&gt;&#10;
                        • API key: X-Api-Key: &lt;key&gt;
                      </TextBlock>
                    </StackPanel>
                  </Border>
                </TabItem>

                <!-- Raw request preview (read-only) -->
                <TabItem Header="Raw">
                  <TextBox Text="{Binding RequestRaw}"
                           IsReadOnly="True"
                           AcceptsReturn="True"
                           TextWrapping="NoWrap"
                           FontFamily="Consolas,Courier New,monospace"
                           FontSize="12"
                           Padding="12"
                           Background="{DynamicResource AppBg}"
                           BorderThickness="0"
                           Foreground="{DynamicResource TextPrimary}" />
                </TabItem>

              </TabControl>

              <!-- ===== SPLITTER ===== -->
              <GridSplitter Grid.Row="2"
                            Background="{DynamicResource BorderColor}"
                            ResizeDirection="Rows" />

              <!-- ===== RESPONSE PANEL ===== -->
              <Grid Grid.Row="3" RowDefinitions="Auto,*" Background="{DynamicResource AppBg}">

                <!-- Response status bar -->
                <Border Grid.Row="0"
                        Padding="10,6"
                        Background="{DynamicResource SidebarBg}"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource BorderColor}">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="16">

                      <!-- Spinner while sending -->
                      <TextBlock Text="Sending…"
                                 Foreground="{DynamicResource TextMuted}"
                                 FontSize="12"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding IsSending}" />

                      <!-- Status code -->
                      <TextBlock Text="{Binding ResponseStatus}"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 Foreground="{Binding ResponseStatusColor, Converter={x:Static conv:StringToBrushConverter.Instance}}"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding HasResponse}" />

                      <!-- Response time -->
                      <TextBlock Text="{Binding ResponseTime}"
                                 FontSize="12"
                                 Foreground="{DynamicResource TextFaint}"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding HasResponse}" />

                      <!-- Response size -->
                      <TextBlock Text="{Binding ResponseSize}"
                                 FontSize="12"
                                 Foreground="{DynamicResource TextFaint}"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding HasResponse}" />
                    </StackPanel>

                    <!-- Hint when no response -->
                    <TextBlock Grid.Column="1"
                               Text="Hit Send to get a response"
                               Foreground="{DynamicResource TextVeryFaint}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               IsVisible="{Binding !HasResponse}" />
                  </Grid>
                </Border>

                <!-- Response content tabs -->
                <TabControl Grid.Row="1" Background="{DynamicResource AppBg}">

                  <!-- Response headers -->
                  <TabItem Header="Headers">
                    <ScrollViewer Background="{DynamicResource AppBg}">
                      <ItemsControl ItemsSource="{Binding ResponseHeaders}" Margin="8,4">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:HeaderItemViewModel">
                            <Grid ColumnDefinitions="*,*" Margin="0,2">
                              <SelectableTextBlock Grid.Column="0"
                                         Text="{Binding Key}"
                                         FontWeight="SemiBold"
                                         FontSize="12"
                                         Foreground="{DynamicResource TextHeaderKey}"
                                         FontFamily="Consolas,monospace"
                                         TextWrapping="Wrap" />
                              <SelectableTextBlock Grid.Column="1"
                                         Text="{Binding Value}"
                                         FontSize="12"
                                         Foreground="{DynamicResource TextSecondary}"
                                         TextWrapping="Wrap"
                                         Margin="8,0,0,0" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </TabItem>

                  <!-- Response body (pretty-printed) -->
                  <TabItem Header="Body">
                    <TextBox Text="{Binding ResponseBody}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas,Courier New,monospace"
                             FontSize="12"
                             Padding="12"
                             Background="{DynamicResource AppBg}"
                             BorderThickness="0"
                             Foreground="{DynamicResource TextPrimary}" />
                  </TabItem>

                  <!-- Raw (full HTTP exchange: request line + sent headers + response headers + body) -->
                  <TabItem Header="Raw">
                    <TextBox Text="{Binding ResponseRawBody}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas,Courier New,monospace"
                             FontSize="12"
                             Padding="12"
                             Background="{DynamicResource AppBg}"
                             BorderThickness="0"
                             Foreground="{DynamicResource TextPrimary}" />
                  </TabItem>

                </TabControl>
              </Grid>

            </Grid>
          </DataTemplate>
        </ContentControl.DataTemplates>
      </ContentControl>

    </Grid>

    <!-- ===== NAME DIALOG OVERLAY (new collection / new folder / rename) ===== -->
    <Border Grid.Column="0" Grid.ColumnSpan="3"
            IsVisible="{Binding IsNameDialogOpen}"
            Background="#88000011">
      <Border Width="360"
              Background="{DynamicResource DialogBg}"
              BorderBrush="{DynamicResource DialogBorderColor}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="24"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
        <StackPanel Spacing="16">

          <TextBlock Text="{Binding NameDialogTitle}"
                     FontSize="16" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimary}" />

          <TextBox Text="{Binding NameDialogValue}"
                   Padding="10,8"
                   FontSize="13" />

          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Background="{DynamicResource BtnSecondaryBg}"
                    Foreground="{DynamicResource TextSecondary}"
                    BorderThickness="0"
                    Padding="16,8"
                    CornerRadius="4"
                    Command="{Binding CancelNameDialogCommand}">Cancel</Button>
            <Button Classes="send-btn"
                    Command="{Binding ConfirmNameDialogCommand}">OK</Button>
          </StackPanel>

        </StackPanel>
      </Border>
    </Border>

    <!-- ===== SAVE REQUEST DIALOG OVERLAY ===== -->
    <Border Grid.Column="0" Grid.ColumnSpan="3"
            IsVisible="{Binding IsSaveDialogOpen}"
            Background="#88000011">
      <Border Width="420"
              Background="{DynamicResource DialogBg}"
              BorderBrush="{DynamicResource DialogBorderColor}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="24"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
        <StackPanel Spacing="16">

          <TextBlock Text="Save Request"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimary}" />

          <!-- Request name -->
          <StackPanel Spacing="6">
            <TextBlock Text="Request Name" FontSize="12" Foreground="{DynamicResource TextMuted}" />
            <TextBox Text="{Binding SaveRequestName}"
                     Padding="10,8"
                     FontSize="13" />
          </StackPanel>

          <!-- Collection selection -->
          <StackPanel Spacing="6">
            <TextBlock Text="Save to Collection / Folder" FontSize="12" Foreground="{DynamicResource TextMuted}" />
            <ListBox ItemsSource="{Binding FlatSaveTargets}"
                     SelectedItem="{Binding SelectedSaveTarget}"
                     MaxHeight="200"
                     Background="{DynamicResource SidebarBg}"
                     BorderBrush="{DynamicResource BorderColor}"
                     BorderThickness="1">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:CollectionTreeNodeViewModel">
                  <TextBlock Text="{Binding FlatTargetDisplayName}"
                             FontFamily="Consolas,monospace"
                             Padding="4" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>

          <!-- Buttons -->
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Background="{DynamicResource BtnSecondaryBg}"
                    Foreground="{DynamicResource TextSecondary}"
                    BorderThickness="0"
                    Padding="16,8"
                    CornerRadius="4"
                    Command="{Binding CancelSaveDialogCommand}">Cancel</Button>
            <Button Classes="send-btn"
                    Command="{Binding SaveRequestCommand}">Save</Button>
          </StackPanel>

        </StackPanel>
      </Border>
    </Border>

    <!-- ===== DELETE CONFIRMATION DIALOG OVERLAY ===== -->
    <Border Grid.Column="0" Grid.ColumnSpan="3"
            IsVisible="{Binding IsDeleteDialogOpen}"
            Background="#88000011">
      <Border Width="360"
              Background="{DynamicResource DialogBg}"
              BorderBrush="{DynamicResource DialogBorderColor}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="24"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
        <StackPanel Spacing="16">

          <TextBlock Text="Delete"
                     FontSize="16" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimary}" />

          <TextBlock FontSize="13" TextWrapping="Wrap"
                     Foreground="{DynamicResource TextSecondary}">
            <Run Text="Are you sure you want to delete '" />
            <Run Text="{Binding DeleteDialogNodeName}" FontWeight="SemiBold" />
            <Run Text="'? This cannot be undone." />
          </TextBlock>

          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Background="{DynamicResource BtnSecondaryBg}"
                    Foreground="{DynamicResource TextSecondary}"
                    BorderThickness="0"
                    Padding="16,8"
                    CornerRadius="4"
                    Command="{Binding CancelDeleteCommand}">Cancel</Button>
            <Button Background="#CC2222"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="16,8"
                    CornerRadius="4"
                    Command="{Binding ConfirmDeleteCommand}">Delete</Button>
          </StackPanel>

        </StackPanel>
      </Border>
    </Border>

  </Grid>
</Window>
